# Copy this file to .env and fill in real values. .env is gitignored.

# Password required to access the live-scan panel (/login, /scan).
PORTFOLIO_PASSWORD=change-me

# Random secret used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-too

# Port the dashboard listens on.
PORT=4000
